FROM python:3.12-slim  # Imagen base mínima con Python 3.12.
WORKDIR /app  # Directorio de trabajo dentro del contenedor.
COPY server.py .  # Copia el servidor UDP al contenedor.
ENV SERVER_BIND_HOST=0.0.0.0  # En contenedor, escuchar en todas las interfaces para aceptar tráfico externo.
CMD ["python", "server.py"]  # Comando por defecto: ejecutar el servidor.
